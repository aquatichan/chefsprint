rules_version = '2';

// Clients never read Cloud Storage directly. The engine writes cookbook files
// with the Admin SDK (which bypasses these rules) and streams them back through
// its own authenticated proxy (GET /cookbooks/{id}/{kind}), which enforces each
// cookbook's `public` flag and ownership. So all direct client access is denied:
// objects are never public, which is what keeps `public: false` cookbooks private.
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
