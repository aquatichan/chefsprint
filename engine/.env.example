# ---- Chefsprint engine configuration (copy to .env) ----

# AI: Google Gemini (request understanding + recipe modification). Optional —
# without it the engine uses a deterministic heuristic fallback.
GEMINI_API_KEY=

# Optional model overrides
# GEMINI_MODEL_PARSE=gemini-2.5-flash-lite
# GEMINI_MODEL_MODIFY=gemini-2.5-flash

# Search: Tavily (recipe URL discovery). Optional — falls back to keyless
# DuckDuckGo Lite (rate-limited) or accepts pasted recipe URLs.
TAVILY_API_KEY=

# Firebase Admin (auth verification, Firestore, Cloud Storage). Optional — the API
# runs in open local mode without these, writing output to local disk.
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/serviceAccount.json
# FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# CORS origins for the web app (comma-separated)
CHEFSPRINT_CORS=http://localhost:3000
